<style>
  /* ====== FONT & BASE ====== */
  @import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600&display=swap");

  html,
  body {
    margin: 0;
    padding: 0;
  }

  :root {
    /* CHANGE TINT COLOR HERE: Adjust the RGBA values (Red, Green, Blue, Opacity) */
    --aat-section-tint: rgba(0, 0, 0, 0.65); 
  }

  .aat-page {
    background: 
      /* Subtle noise/grain overlay */
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.03) 0px,
        rgba(255, 255, 255, 0.03) 1px,
        rgba(0, 0, 0, 0.02) 1px,
        rgba(0, 0, 0, 0.02) 2px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.02) 0px,
        rgba(255, 255, 255, 0.02) 1px,
        rgba(0, 0, 0, 0.03) 1px,
        rgba(0, 0, 0, 0.03) 2px
      ),
      /* Radial gradient from corners for depth */
      radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.08), transparent 50%),
      radial-gradient(circle at 100% 100%, rgba(255, 255, 255, 0.06), transparent 50%),
      radial-gradient(circle at 100% 0%, rgba(0, 0, 0, 0.15), transparent 50%),
      radial-gradient(circle at 0% 100%, rgba(0, 0, 0, 0.12), transparent 50%),
      /* Main linear gradient for brightness variation */
      linear-gradient(180deg, #080809 0%, #0f0f14 25%, #121218 50%, #0f0f14 75%, #080809 100%),
      /* Base color */
      #050507;
    background-attachment: fixed;
    color: #f5f5f5;
    font-family: "Space Grotesk", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .aat-container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  a.aat-link {
    text-decoration: none;
    color: inherit;
  }

/* ====== NAVBAR ====== */
.aat-nav-wrap {
  position: sticky;
  top: 0;
  z-index: 40;
  padding: 0;
  backdrop-filter: blur(18px);
  background: linear-gradient(to bottom, rgba(10, 10, 14, 0.95), rgba(10, 10, 14, 0.85), transparent);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

  .aat-nav {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 1.5rem !important;
  padding: 0 1.5rem !important;
  position: relative !important;
  height: 80px !important;
  min-height: 80px !important;
  flex-wrap: nowrap !important;
}

.aat-logo {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  flex-shrink: 0 !important;
  height: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  min-width: 0 !important;
}

.aat-logo a {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  height: 100% !important;
  width: auto !important;
  padding: 0 !important;
}

.aat-logo-img {
  height: 110% !important;
  width: auto !important;
  max-height: 100px !important;
  display: block !important;
  object-fit: contain !important;
  object-position: center !important;
  margin: 0 !important;
  padding: 0 !important;
  transform: translateY(-8px) !important; 
}

.aat-nav-links {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 1.75rem;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: rgba(255, 255, 255, 0.55);
  margin: 0;
  padding: 0;
}

.aat-nav-links a {
  position: relative;
  display: inline-flex;
  align-items: center;
  height: 100%;
}

.aat-nav-links a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -0.35rem;
  width: 0;
  height: 1px;
  background: #ffffff;
  transition: width 0.18s ease-out;
}

.aat-nav-links a:hover::after {
  width: 100%;
}

.aat-nav-links a:hover {
  color: #ffffff;
}

.aat-nav-cta {
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  padding: 0.85rem 1.6rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.28);
  color: #ffffff;
  background: radial-gradient(circle at 0 0, rgba(255, 255, 255, 0.18), transparent 55%);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  cursor: pointer;
  white-space: nowrap;
  line-height: 1;
  margin: 0;
  flex-shrink: 0;
}

.aat-nav-cta:hover {
  border-color: rgba(255, 255, 255, 0.7);
}

@media (min-width: 768px) {
  .aat-nav-links {
    display: flex;
  }
}

@media (max-width: 1024px) {
  .aat-nav {
    height: 70px !important;
    min-height: 70px !important;
    padding: 0 1.2rem !important;
    gap: 1.2rem !important;
  }

  .aat-logo-img {
    max-height: 65px !important;
  }
}

@media (max-width: 768px) {
  .aat-nav {
    height: 65px !important;
    min-height: 65px !important;
    padding: 0 1rem !important;
    gap: 0.8rem !important;
  }

  .aat-logo-img {
    max-height: 55px !important;
  }

  .aat-nav-cta {
    padding: 0.6rem 1rem;
    font-size: 0.7rem;
  }
}

@media (max-width: 640px) {
  .aat-nav {
    height: 60px !important;
    min-height: 60px !important;
    padding: 0 0.8rem !important;
    gap: 0.6rem !important;
  }

  .aat-logo-img {
    max-height: 50px !important;
  }

  .aat-nav-cta {
    padding: 0.5rem 0.8rem;
    font-size: 0.65rem;
  }
}

@media (max-width: 480px) {
  .aat-nav {
    height: 55px !important;
    min-height: 55px !important;
    padding: 0 0.6rem !important;
    gap: 0.5rem !important;
  }

  .aat-logo-img {
    max-height: 45px !important;
  }

  .aat-nav-cta {
    padding: 0.4rem 0.7rem;
    font-size: 0.6rem;
  }
}

  /* ====== GENERIC SECTIONS ====== */
  .aat-section {
    padding: 5rem 0;
    position: relative;
  }

  .aat-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
    pointer-events: none;
  }

  .aat-section.dark {
    background: linear-gradient(180deg, #06080c 0%, #090c11 50%, #06080c 100%);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  .aat-section.light {
    background: linear-gradient(180deg, #0a0d13 0%, #0e1117 50%, #0a0d13 100%);
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .aat-section-header {
    margin-bottom: 3rem;
    max-width: 640px;
  }

  .aat-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.75rem;
  }

  .aat-section-title {
    font-family: "Bebas Neue", system-ui, sans-serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .aat-section-sub {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.82);
  }

  /* ====== HERO SECTION – VIDEO PARALLAX ====== */
  .aat-hero {
    position: relative;
    overflow: hidden;
    min-height: min(100vh, 820px);
    display: flex;
    align-items: flex-end;
    padding: 5.5rem 0 3.5rem;
  }

  .aat-hero-bg {
    position: absolute;
    inset: -10vh 0 -10vh 0;
    overflow: hidden;
    z-index: 0;
  }

  .aat-hero-video {
    width: 100%;
    height: 120%;
    object-fit: cover;
    object-position: center 63%;
    transform: translateY(0) scale(1.05);
    will-change: transform;
    filter: brightness(1.08) contrast(1.02);
  }

  .aat-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.35) 50%, rgba(0, 0, 0, 0.5) 100%);
  }

  .aat-hero-inner {
    position: relative;
    z-index: 2;
  }

  .aat-hero-topline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .aat-hero-pill {
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .aat-hero-headline {
    font-family: "Bebas Neue", system-ui, sans-serif;
    font-size: clamp(3.2rem, 8vw, 5.6rem);
    line-height: 0.9;
    letter-spacing: 0.06em;
    color: #ffffff;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .aat-hero-sub {
    max-width: 460px;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 2rem;
  }

  .aat-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .aat-btn-primary,
  .aat-btn-secondary {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    padding: 0.9rem 1.8rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    background: transparent;
    color: #ffffff;
  }

  .aat-btn-primary {
    background: linear-gradient(135deg, #ffffff, #b3b3b3);
    color: #050507;
    border-color: transparent;
  }

  .aat-btn-primary:hover {
    filter: brightness(1.03);
  }

  .aat-btn-secondary {
    background: rgba(5, 5, 7, 0.4);
  }

  .aat-btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.7);
  }

  .aat-hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .aat-stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.25rem;
  }

  .aat-stat-value {
    font-size: 1.2rem;
    font-weight: 500;
  }

  .aat-stat-note {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 768px) {
    .aat-section {
      padding: 2.8rem 0;
    }

    .aat-hero {
      padding: 3rem 0 2rem;
      min-height: 70vh;
    }

    .aat-hero-stats {
      grid-template-columns: 1fr;
      gap: 1.2rem;
      padding-top: 1.2rem;
    }

    .aat-hero-headline {
      font-size: clamp(2rem, 6vw, 2.8rem);
      line-height: 1.1;
      margin-bottom: 0.8rem;
    }

    .aat-hero-sub {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }

    .aat-hero-ctas {
      gap: 0.7rem;
      margin-bottom: 1.5rem;
    }

    .aat-btn-primary,
    .aat-btn-secondary {
      padding: 0.8rem 1.6rem;
      font-size: 0.75rem;
    }

    .aat-stat-label {
      font-size: 0.7rem;
    }

    .aat-stat-value {
      font-size: 1.1rem;
    }

    .aat-stat-note {
      font-size: 0.7rem;
    }
  }

  @media (max-width: 640px) {
    .aat-section {
      padding: 2.4rem 0;
    }

    .aat-hero {
      padding: 2.5rem 0 1.8rem;
      min-height: 65vh;
    }

    .aat-hero-topline {
      gap: 0.5rem;
      margin-bottom: 0.7rem;
      font-size: 0.65rem;
    }

    .aat-hero-pill {
      padding: 0.3rem 0.7rem;
      font-size: 0.6rem;
      border-radius: 999px;
    }

    .aat-hero-headline {
      font-size: clamp(1.6rem, 5.5vw, 2.2rem);
      line-height: 1.1;
      margin-bottom: 0.7rem;
    }

    .aat-hero-sub {
      font-size: 0.82rem;
      line-height: 1.5;
      margin-bottom: 1.2rem;
    }

    .aat-hero-ctas {
      gap: 0.5rem;
      margin-bottom: 1rem;
      flex-direction: column;
    }

    .aat-btn-primary,
    .aat-btn-secondary {
      padding: 0.7rem 1.4rem;
      font-size: 0.7rem;
      width: 100%;
      justify-content: center;
    }

    .aat-hero-stats {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      padding-top: 0.9rem;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .aat-stat-label {
      font-size: 0.6rem;
      margin-bottom: 0.2rem;
    }

    .aat-stat-value {
      font-size: 0.95rem;
    }

    .aat-stat-note {
      font-size: 0.6rem;
      line-height: 1.4;
    }
  }

  @media (max-width: 480px) {
    .aat-section {
      padding: 2rem 0;
    }

    .aat-hero {
      padding: 2rem 0 1.5rem;
      min-height: 60vh;
    }

    .aat-hero-headline {
      font-size: clamp(1.4rem, 5vw, 1.8rem);
    }

    .aat-hero-sub {
      font-size: 0.78rem;
    }

    .aat-hero-ctas {
      margin-bottom: 0.8rem;
    }

    .aat-btn-primary,
    .aat-btn-secondary {
      padding: 0.65rem 1.2rem;
      font-size: 0.65rem;
    }
  }

  /* ====== GALLERY BANNER (ABOVE SERVICES) ====== */
  .aat-gallery-banner-wrap {
    padding-top: 0.5rem;
  }

  .aat-gallery-banner {
    border-radius: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: radial-gradient(circle at 0% 0%, rgba(255, 255, 255, 0.04), transparent 65%),
      radial-gradient(circle at 100% 100%, rgba(255, 255, 255, 0.02), transparent 60%),
      linear-gradient(180deg, #0a0d12 0%, #07090d 100%);
    padding: 0.75rem 0;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .aat-gallery-track {
    display: flex;
    gap: 1rem;
    animation: aat-gallery-scroll 28s linear infinite;
    will-change: transform;
  }

  .aat-gallery-slide {
    flex: 0 0 auto;
    width: 340px;
  }

  .aat-gallery-slide img {
    width: 100%;
    height: 220px;
    border-radius: 1.1rem;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease-out;
  }

  .aat-gallery-slide img:hover {
    transform: scale(1.04);
  }

  .aat-gallery-banner-caption {
    margin-top: 1.2rem;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.6);
  }

  @keyframes aat-gallery-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .aat-gallery-banner-wrap {
      padding-top: 0.4rem;
    }

    .aat-gallery-slide {
      width: 280px;
    }

    .aat-gallery-slide img {
      height: 190px;
    }

    .aat-gallery-track {
      animation-duration: 28s;
      gap: 0.9rem;
    }

    .aat-gallery-banner-caption {
      margin-top: 1rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 640px) {
    .aat-gallery-slide {
      width: 240px;
    }

    .aat-gallery-slide img {
      height: 160px;
      border-radius: 0.9rem;
    }

    .aat-gallery-track {
      animation-duration: 24s;
      gap: 0.7rem;
    }

    .aat-gallery-banner-caption {
      margin-top: 0.8rem;
      font-size: 0.7rem;
    }
  }

  @media (max-width: 480px) {
    .aat-gallery-slide {
      width: 200px;
    }

    .aat-gallery-slide img {
      height: 135px;
    }

    .aat-gallery-track {
      animation-duration: 20s;
      gap: 0.6rem;
    }

    .aat-gallery-banner-caption {
      margin-top: 0.7rem;
      font-size: 0.65rem;
    }
  }

  /* ====== SERVICES SECTION – ROBUST DARK TINT ====== */
  #services {
    position: relative;
    z-index: 0;
    background-image: linear-gradient(var(--aat-section-tint), var(--aat-section-tint)), url("https://assets.cdn.filesafe.space/HCGFK8ffPmAyOjnSFsyb/media/b2b3679d-047d-4d97-9edd-25cee584aab4.jpeg");
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    background-attachment: fixed;
  }

  #services > .aat-container {
    position: relative;
    z-index: 2;
  }

  @media (max-width: 768px) {
    #services {
      background-attachment: scroll;
      background-position: center top;
    }
  }

  /* ====== SERVICES ====== */
  .aat-services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .aat-services-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .aat-service-card {
